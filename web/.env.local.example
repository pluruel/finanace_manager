# auth-svc 기본 URL (서버 사이드에서만 사용)
AUTH_BASE_URL=https://auth.junodevs.com

# Rust 백엔드 API URL (브라우저에서 직접 호출하지 않음 — Route Handler 경유)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Docker compose 내부 네트워크에서는 컨테이너 서비스명 사용
# API_BASE_URL_INTERNAL=http://server:8000

# 서비스명 (참고용, 실제 JWT 검증은 백엔드가 담당)
SERVICE_NAME=finance-manager
